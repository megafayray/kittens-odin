<h1>All Kittens</h1>

<% if @kittens.any? %>
    <ul>
        <% @kittens.each do |kitten| %>
            <li>
                <%= link_to kitten.name, kitten_path(kitten) %>
                <%= link_to "Delete", kitten, data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this kitten?" } %>
            </li>
        <% end %>
    </ul>
<% else %>
    No kittens, how sad. <%=link_to "You need some kittens in your life", new_kitten_path %>
<% end %>