<h1>All Kittens</h1>

<% if @kittens.any? %>
    <% @kittens.each do |kitten| %>
    <%= link_to kitten.name, kitten_path(kitten) %>
    <%= link_to "Delete", kitten_path(kitten), method: :delete, data: { confirm: "Are you sure you want to delete this kitten?" } %>
    <% end %>
<% else %>
    No kittens, how sad. <%=link_to "You need some kittens in your life", new_kitten_path %>
<% end %>